{
  "name": "todolist",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build:win": "vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.todolist.app",
    "productName": "ToDoList",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/jre",
        "to": "resources/jre"
      },
      {
        "from": "../demo/target/demo-0.0.1-SNAPSHOT.jar",
        "to": "resources/demo-0.0.1-SNAPSHOT.jar"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}